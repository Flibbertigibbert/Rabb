# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — server-side only, NEVER prefix with NEXT_PUBLIC_,
# never import in client components. Used in Phase 3 for checkout/webhook writes.
SUPABASE_SERVICE_ROLE_KEY=

# Paystack Settings → API Keys & Webhooks in your Paystack dashboard.
# Use the TEST secret key (starts with sk_test_) until you're ready to go live.
PAYSTACK_SECRET_KEY=
